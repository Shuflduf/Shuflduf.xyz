---
import type { ProjectsEntry, MenuItem } from "@/types";
import EntryLayout from "@components/docs/EntryLayout.astro";
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import getNotionContent from "@lib/notion/getNotionContent";
import getNotionPaths from "@lib/notion/getNotionPaths";
import pathsToTree from "@lib/pathToTree";
import type { TreeNode } from "@lib/pathToTree";


export async function getStaticPaths() {
  const rawPaths = await getNotionPaths("/projects");
  const paths = rawPaths.map((path) => ({
    params: { id: path.path },
  }));
  return paths;
}

const { id = "" } = Astro.params;
const rawPaths = await getNotionPaths("/projects");
const tree = pathsToTree(rawPaths);

let isLeaf = rawPaths.map((v) => (v as any).path).includes(`/${id}`)
console.log("VALID PATH: ", isLeaf);
// let isGroup = !isLeaf;

let content: ProjectsEntry | null = null;
if (isLeaf) {
  const pagePath = `/projects/${id}`;
  const pageContent = await getNotionContent(pagePath);
  content = {
    id,
    data: {
      title: pageContent.name || "Untitled",
      description: pageContent.description || "",
      autodescription: false,
      draft: false,
      imageAlt: "",
      hideToc: false,
      hideNav: false,
    },
    body: pageContent.pageContent || "",
    collection: "projects",
  };
}
// const groupEntries =
//   isGroup && typeof currentNode === "object"
//     ? Array.isArray(currentNode)
//       ? currentNode.map((entry) => ({
//           id: id ? `${id}/${entry}` : entry,
//           data: { title: entry },
//         }))
//       : Object.entries(currentNode).map(([key, value]) => ({
//           id: id ? `${id}/${key}` : key,
//           data: { title: key },
//         }))
//     : [];

// Build browser menu from tree
const buildMenu = (node: TreeNode, parentPath: string = ""): MenuItem[] => {
  if (typeof node === "string") {
    const fullPath = parentPath ? `${parentPath}/${node}` : node;
    return [{
      title: node,
      path: fullPath,
      children: []
    }];
  }

  return Object.entries(node).flatMap(([key, value]) => {
    const fullPath = parentPath ? `${parentPath}/${key}` : key;
    return [{
      title: (value as any)["name"],
      path: fullPath,
      children: buildMenu(value, fullPath)
    }];
  });
};

const browserMenu = buildMenu(tree);
---

{
isLeaf ? (
<EntryLayout
  entry={content}
  browserMenu={browserMenu}
/>
  ) : (
  <h1>adpoakjd</h1>
  )
}


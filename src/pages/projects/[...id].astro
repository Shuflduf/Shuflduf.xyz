---
import type { ProjectsEntry, MenuItem } from "@/types";
import EntryLayout from "@components/docs/EntryLayout.astro";
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import { getEntries, getEntriesInGroup, getGroups } from "@lib/contentParser";
import { sortByTitle } from "@lib/sortFunctions";
import getNotionContent from "@lib/notion/getNotionContent";
import formatNotionContent from "@lib/notion/formatNotionContent";
import getNotionPaths from "@lib/notion/getNotionPaths";
import pathsToTree from "@lib/pathToTree";
import console from "console";

export async function getStaticPaths() {
  const entries = (await getEntries(
    "projects",
    sortByTitle,
  )) as ProjectsEntry[];

  const paths = entries.map((entry) => {
    const segments = entry.id.replace("/-index", "").split("/");

    if (segments.length === 1) {
      return {
        params: { id: segments[0] },
        props: { entry, isGroup: true },
      };
    } else if (segments.length === 2) {
      return {
        params: { id: entry.id },
        props: { entry, isGroup: false },
      };
    }
  });

  return paths;
}

const { entry, isGroup } = Astro.props;
const id = entry.id;
const groupName = id.replace("/-index", "");
const groupEntries = isGroup
  ? ((await getEntriesInGroup(
      "projects",
      groupName,
      sortByTitle,
    )) as ProjectsEntry[])
  : [];

const content = await getNotionContent(`/projects/${id}`);
const pageEntry = {
  ...entry, // Keep the original entry properties
  body: content.pageContent,
  data: {
    ...entry.data,
    title: content.name,
    description: content.description,
    pubDate: content.createdAt,
    modDate: content.lastModified,
  },
};

// Construct Doc Browser menu
const browserMenu: MenuItem[] = [];
const groups = (await getGroups("projects", sortByTitle)) as ProjectsEntry[];
await Promise.all(
  groups.map(async (group) => {
    const groupEntries = (await getEntriesInGroup(
      "projects",
      group.id.replace("/-index", ""),
      sortByTitle,
    )) as ProjectsEntry[];
    browserMenu.push({
      title: group.data.title,
      id: group.id.replace("/-index", ""),
      children: groupEntries.map((groupEntry) => ({
        title: groupEntry.data.title,
        id: groupEntry.id,
        children: [],
      })),
    });
  }),
);
const paths = await getNotionPaths("/");
const tree = pathsToTree(paths);
console.log(JSON.stringify(tree, null, 2));
---

{
  isGroup ? (
    <CollectionLayout
      collectionIndex={entry}
      entries={groupEntries}
      collection="projects"
    />
  ) : (
    <EntryLayout
      entry={pageEntry}
      browserMenu={browserMenu}
      collection="projects"
    />
  )
}

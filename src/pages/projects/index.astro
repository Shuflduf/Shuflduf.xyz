---
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import type { ProjectsEntry } from "@/types";
import getNotionPaths from "@lib/notion/getNotionPaths";
import pathsToTree from "@lib/pathToTree";
import LoadingScreen from "@components/LoadingScreen.astro";

const notionPaths = await getNotionPaths("/projects");
const tree = pathsToTree(notionPaths);

// Create collection index
const collectionIndex: ProjectsEntry = {
  id: "projects",
  data: {
    title: "Projects",
    description: "My programming projects",
    autodescription: false,
    draft: false,
    imageAlt: "Projects overview",
    hideToc: false,
    hideNav: false,
  },
  collection: "projects",
};

const groupIndices = Object.entries(tree).map(([key, value]) => ({
  id: key,
  data: {
    title: (value as any)["name"],
    description: `Group: ${key}`,
    autodescription: false,
    draft: false,
    imageAlt: `${key} overview`,
    hideToc: false,
    hideNav: false,
  },
  collection: "projects",
}));
---

<LoadingScreen />
<CollectionLayout
  entries={groupIndices}
  collectionIndex={collectionIndex}
  collection="projects"
/>

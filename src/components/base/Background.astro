---
// Twinkling Star Background
const numStars = 160;
const stars = Array.from({ length: numStars }).map(() => ({
  left: `${Math.random() * 100}%`,
  top: `${Math.random() * 100}%`,
  size: `${Math.random() * 4 + 1}px`,
  delay: `${7 * Math.random()}s`,
  // hsl: `hsl(${Math.random() * 360}, 100%, 50%)`, // background: ${hsl};
}));
---

<div
  class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden"
>
  {
    stars.map(({ left, top, size, delay }) => (
      <div
        class="absolute bg-none dark:bg-yellow-50 rounded-full animate-twinkle"
        style={`
            left: ${left};
            top: ${top};
            width: ${size};
            height: ${size};
            animation-delay: ${delay};
        `}
      />
    ))
  }
</div>
<!-- Gradient Cycle Background -->
<div
  class="gradient animate-cycleBg fixed top-0 left-0 w-full h-full -z-1 pointer-events-none overflow-hidden opacity-100 dark:opacity-0"
>
</div>
<style>
  .gradient {
    background: #f7c7b6;
    animation: colorFade 20s ease infinite;
  }

  @keyframes colorFade {
    0% {
      background: #f7c7b6;
    }
    25% {
      background: #f7b7d1;
    }
    50% {
      background: #b7e0f2;
    }
    75% {
      background: #b7ede0;
    }
    100% {
      background: #f7c7b6;
    }
  }
</style>

---
import { ScrollArea } from "@components/common/shortcodes/ScrollArea";
import type { MenuItem } from "@/types";

interface Props {
  menu: MenuItem[];
  currentPage: string;
  collection?: string;
}

const { menu, currentPage, collection = "docs" } = Astro.props;
const title = collection === "docs" ? "Documents" : "Projects";
---

<div class="w-full h-full bg-surface dark:bg-darkmode-surface rounded-lg">
  {
    menu.length > 0 && (
      <div class="relative glass rounded-lg p-4 m-2 w-[100%-1] intersect:animate-fadeRight opacity-0 ">
        <ScrollArea className="h-full" client:only="react">
          <h2 class="text-2xl border-none">{title}</h2>
          <ul class="list-none m-0">
            {menu.map((item) => (
              <li class="ml-0">
                <a
                  href={`/${collection}/${item.id}`}
                  class={`w-full leading-none no-underline ${
                    item.id === currentPage ? "font-bold" : ""
                  }`}
                >
                  {item.title}
                </a>
                {item.children.length > 0 && (
                  <ul class="list-none m-0">
                    {item.children.map((child) => (
                      <li class="ml-4">
                        <a
                          href={`/${collection}/${child.id}`}
                          class={`w-full leading-none no-underline ${
                            child.id === currentPage ? "font-bold" : ""
                          }`}
                        >
                          {child.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </ScrollArea>
      </div>
    )
  }
</div>
